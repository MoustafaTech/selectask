{
  "name": "rex",
  "productName": "Rex",
  "version": "0.8.1",
  "description": "Select text anywhere, tap Ctrl, and Rex the pixel dino fetches you an AI answer.",
  "main": "src/main/index.js",
  "author": "MoustafaTech <moustafaessam2212@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/MoustafaTech/rex",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoustafaTech/rex.git"
  },
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/gen-icons.js",
    "dist": "electron-builder",
    "dist:all": "electron-builder -mwl"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.moustafatech.rex",
    "npmRebuild": false,
    "productName": "Rex",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "MoustafaTech",
      "repo": "rex"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Rex simulates a copy keystroke to capture the text you selected.",
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
